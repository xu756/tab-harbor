{
  "manifest_version": 3,
  "name": "Tab Harbor",
  "short_name": "Tab Harbor",
  "version": "1.1.1",
  "description": "A quiet new tab workspace for organizing tabs, quick links, todos, notes, and saved sessions locally.",
  "homepage_url": "https://github.com/xu756/tab-harbor",
  "permissions": ["tabs", "storage", "search", "clipboardRead", "tabGroups", "favicon"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Harbor",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
